# ═══════════════════════════════════════════════════════════
#  WasteVision – .env.example
#  Bu dosya GIT'e commit edilir (gerçek değer içermez).
#  Kopyalayıp .env olarak kaydedin ve değerleri doldurun.
#  Alper & Sabri: .env.example → .env kopyalayıp doldurun!
# ═══════════════════════════════════════════════════════════

# ─── Solana Ağ Yapılandırması ─────────────────────────────
# Kullanılacak Solana cluster: devnet | testnet | mainnet-beta
VITE_SOLANA_NETWORK=devnet

# Solana RPC Endpoint (boş bırakılırsa varsayılan kullanılır)
# Ücretsiz: https://api.devnet.solana.com
# Premium (QuickNode, Helius vb. için): https://rpc-url-buraya.example.com
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Program ID ───────────────────────────────────────────
# Anchor build sonrası oluşan program public key
VITE_PROGRAM_ID=BZmQnBUZS1aQfjXCC7y4LnVxjjujzT6jvDhNrdforWA3

# ─── AI / External API (varsa) ────────────────────────────
# Eleven Labs TTS API (henüz kullanılmıyor, ilerisi için)
VITE_ELEVENLABS_API_KEY=

# Google Cloud Vision API (alternatif AI backend için)
VITE_GOOGLE_VISION_API_KEY=

# Overpass API (varsayılan public, rate-limit aşılırsa özel endpoint ekle)
VITE_OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ─── Geliştirici Ayarları ─────────────────────────────────
# true → konum doğrulamasını bypass eder (sadece dev ortamında!)
VITE_DEV_MODE=false

# Geliştirici modu şifre (opsiyonel, UI'da toggle için)
VITE_DEV_PASSWORD=
